# Voice Diary — Environment Variables
# Copy to .env and fill in real values before running.

# PostgreSQL
DB_USER=voicediary
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_NAME=voicediary

# App
APP_PORT=8080
API_KEY=CHANGE_ME_GENERATE_A_SECRET

# TLS certs generated by mkcert — see docs/WORKFLOW.md
TLS_CERT_PATH=/path/to/cert.pem
TLS_KEY_PATH=/path/to/key.pem

# AWS credentials (used by both Transcribe and Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Transcription backend: "transcribe" (AWS Transcribe Streaming) or "whisper" (local)
# AWS Transcribe: no S3 needed, uses HTTP/2 streaming. Requires transcribe:* IAM permissions.
# Whisper: self-hosted, no AWS dependency for STT. Uses faster-whisper (CPU, int8).
TRANSCRIPTION_BACKEND=transcribe

# Whisper config (only used when TRANSCRIPTION_BACKEND=whisper)
# Models: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# Bedrock (diary compilation — text only, always used)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# Scheduled compilation time (HH:MM, 24h format)
COMPILE_TIME=03:00
